# Local LLM Configuration (Ollama)
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:3b
OLLAMA_API_URL=http://localhost:11434

# Google Cloud (for future Cloud Run deployment only)
# Point OLLAMA_API_URL to your hosted Ollama endpoint when deploying to Cloud Run
GOOGLE_CLOUD_PROJECT=your-google-cloud-project-id
